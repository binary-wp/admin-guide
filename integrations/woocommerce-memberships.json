		{ "slug": "woocommerce-memberships", "label": "Memberships" },
		{ "slug": "woocommerce-memberships-subscriptions", "label": "Memberships & Subscriptions (combo)" }
	],
	"placeholders": {
		"{{woo_memberships_plans_section}}": {
			"callback": "guide_render_woo_memberships_plans_section",
			"description": "Membership plans with restrictions and linked products"
		}
	}
}
